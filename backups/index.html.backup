<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Digital Marketing Services for SaaS | AI-Powered Growth | DigiBrand Booster</title>
    <meta name="description" content="Digital marketing services for SaaS companies. AI-powered, SEO optimized, geographic targeting. Predictable revenue growth with transparent ROI.">
    <meta name="keywords" content="digital marketing services, SaaS marketing, AI marketing, SEO, geographic targeting, growth marketing">
    <link rel="stylesheet" href="styles.css">
</head>
<body>

<!-- HEADER -->
<header class="header">
    <div class="container">
        <div class="header-inner">
            <div class="logo">
                <svg class="logo-svg" viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <!-- Gradient Monogram - Premium Modern Design -->
                    <defs>
                        <linearGradient id="logoGradient" x1="0%" y1="0%" x2="100%" y2="100%">
                            <stop offset="0%" style="stop-color:#a78bfa;stop-opacity:1" />
                            <stop offset="50%" style="stop-color:#6366f1;stop-opacity:1" />
                            <stop offset="100%" style="stop-color:#0056cc;stop-opacity:1" />
                        </linearGradient>
                    </defs>
                    <!-- Modern monogram square -->
                    <rect x="8" y="10" width="32" height="28" fill="none" stroke="url(#logoGradient)" stroke-width="2.5" stroke-linejoin="round"/>
                    <!-- Center dividing line -->
                    <line x1="8" y1="24" x2="40" y2="24" stroke="url(#logoGradient)" stroke-width="1.5"/>
                    <!-- D shape on right -->
                    <path d="M24 12 Q36 12, 36 24 Q36 36, 24 36" fill="none" stroke="url(#logoGradient)" stroke-width="2.5" stroke-linecap="round"/>
                </svg>
                <span>DigiBrand Booster</span>
            </div>
            <button class="mobile-menu-toggle" id="mobileMenuToggle">
                <span></span>
                <span></span>
                <span></span>
            </button>
            <nav class="nav" id="nav">
                <ul>
                    <li><a href="#digital-marketing">Digital Marketing</a></li>
                    <li><a href="#how-it-works">How It Works</a></li>
                    <li><a href="cases.html">Case Studies</a></li>
                    <li><a href="#ai-seo-geo">AI & Optimization</a></li>
                </ul>
            </nav>
            <a href="#growth-review" class="btn btn-primary">Schedule Review</a>
        </div>
    </div>
</header>

